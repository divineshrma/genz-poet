from textblob import TextBlob

def analyze_genz_vibe(text):
    # TextBlob reads the text and gives a polarity score between -1 and 1
    analysis = TextBlob(text)
    score = analysis.sentiment.polarity
    
    if score > 0.1:
        return "Positive Vibe ✨ (W, Based, Fire)"
    elif score < -0.1:
        return "Negative Vibe 🚩 (L, Cringe, Toxic)"
    else:
        return "Neutral Vibe 😐 (Mid, NPC energy)"

print("🚀 Welcome to the Gen-Z Vibe Checker!")
print("-" * 35)

while True:
    user_input = input("Type a sentence or slang (or type 'quit' to exit): ")
    
    if user_input.lower() == 'quit':
        print("Catch you later! Peace out. ✌️")
        break
        
    result = analyze_genz_vibe(user_input)
    print(f"🤖 Vibe Check Result: {result}\n")
